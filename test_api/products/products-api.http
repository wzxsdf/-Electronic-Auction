            client.log("✅ 查询用户商品成功");
            client.log("📊 发布数量: " + body.data.length);
        }
    }
%}

### 6.2 查询已上架商品
GET {{baseUrl}}/products?status=LISTED&page=1&size=10

> {%
    if (response.status === 200) {
        client.log("✅ 查询已上架商品成功");
    }
%}

### 6.3 按价格范围筛选
GET {{baseUrl}}/products?minPrice=1000&maxPrice=10000&page=1&size=10

> {%
    if (response.status === 200) {
        client.log("✅ 价格范围筛选成功");
    }
%}

### ================================================================================
### 🔒 安全和边界测试
### ================================================================================

### 7.1 SQL注入测试
GET {{baseUrl}}/products?keyword=iPhone'; DROP TABLE products;--

> {%
    if (response.status === 200) {
        client.log("✅ SQL注入防护正常");
    } else {
        client.log("⚠️ 需要检查SQL注入防护");
    }
%}

### 7.2 XSS攻击测试
GET {{baseUrl}}/products?keyword=<script>alert('XSS')</script>

> {%
    if (response.status === 400) {
        client.log("✅ XSS防护正常");
    } else {
        client.log("⚠️ 需要检查XSS防护");
    }
%}

### 7.3 价格边界测试
POST {{baseUrl}}/products
Authorization: Bearer {{merchantToken}}
Content-Type: application/json

{
  "name": "负价格测试商品",
  "description": "价格不应该为负数",
  "basePrice": -100.00,
  "category": "ELECTRONICS"
}

> {%
    if (response.status === 400) {
        client.log("✅ 负价格验证正常");
    } else {
        client.log("❌ 负价格验证异常");
    }
%}

### 7.4 超长字符串测试
POST {{baseUrl}}/products
Authorization: Bearer {{merchantToken}}
Content-Type: application/json

{
  "name": "这是一个非常非常非常长的商品名称，超过了数据库字段的最大长度限制，应该被拒绝",
  "description": "正常的描述",
  "basePrice": 100.00,
  "category": "ELECTRONICS"
}

> {%
    if (response.status === 400) {
        client.log("✅ 字符串长度验证正常");
    } else {
        client.log("⚠️ 需要检查字符串长度验证");
    }
%}

### ================================================================================
### 💡 测试注意事项
### ================================================================================

### 1. 确保已执行auth模块的商家登录，获取merchantToken
### 2. 创建商品成功后，productId会自动保存供后续使用
### 3. 拍卖模块依赖商品ID，所以先创建商品
### 4. 图片上传需要配置OSS服务，否则可能失败
### 5. 价格和库存等数值字段有范围限制，注意边界测试

### ================================================================================
### 📋 完整业务流程
### ================================================================================

### 流程：创建商品 → 上架商品 → 上传图片 → 查询商品 → 更新信息 → 下架商品
### 按顺序执行上述接口，验证商品管理完整流程

### ================================================================================