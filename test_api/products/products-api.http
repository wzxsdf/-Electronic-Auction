### ================================================================================
### 📦 商品管理模块接口测试
### ================================================================================
### 功能：商品创建、查询、更新、上架下架、图片管理等
### 依赖：需要商家Token（auth模块）
### 权限：商家/管理员
### ================================================================================

@baseUrl = http://localhost:8080/api
@merchantToken = {{merchantToken}}
@productId = {{productId}}

### ================================================================================
### 🆕 创建商品
### ================================================================================

### 1.1 创建电子产品
POST {{baseUrl}}/products
Authorization: Bearer {{merchantToken}}
Content-Type: application/json

{
  "name": "iPhone 15 Pro Max",
  "description": "全新未拆封，256GB，钛金属原色，支持5G网络",
  "basePrice": 8999.00,
  "category": "ELECTRONICS",
  "brand": "Apple",
  "model": "iPhone 15 Pro Max",
  "images": [
    "https://example.com/iphone1.jpg",
    "https://example.com/iphone2.jpg"
  ]
}

> {%
    if (response.status === 200) {
        var body = JSON.parse(response.body);
        if (body.data && body.data.id) {
            client.global.set("productId", body.data.id);
            client.log("✅ 商品创建成功");
            client.log("📦 商品ID: " + body.data.id);
            client.log("📦 商品名称: " + body.data.name);
            client.log("💰 基础价格: " + body.data.basePrice);
        }
    } else {
        client.log("❌ 商品创建失败: " + response.body);
    }
%}

### 1.2 创建奢侈品
POST {{baseUrl}}/products
Authorization: Bearer {{merchantToken}}
Content-Type: application/json

{
  "name": "LV限量版手提包",
  "description": "全新正品，支持专柜验货",
  "basePrice": 15000.00,
  "category": "LUXURY",
  "brand": "Louis Vuitton",
  "model": "Limited Edition",
  "images": [
    "https://example.com/lv1.jpg"
  ]
}

> {%
    if (response.status === 200) {
        client.log("✅ 奢侈品创建成功");
    }
%}

### 1.3 创建艺术品
POST {{baseUrl}}/products
Authorization: Bearer {{merchantToken}}
Content-Type: application/json

{
  "name": "名家山水画",
  "description": "当代著名画家真迹，附证书",
  "basePrice": 50000.00,
  "category": "ART",
  "brand": "知名画家",
  "model": "山水画",
  "images": [
    "https://example.com/art1.jpg"
  ]
}

> {%
    if (response.status === 200) {
        client.log("✅ 艺术品创建成功");
    }
%}

### 1.4 权限测试 - 普通用户尝试创建商品（应该失败）
POST {{baseUrl}}/products
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "name": "测试商品",
  "description": "普通用户不应该能创建商品",
  "basePrice": 100.00,
  "category": "ELECTRONICS"
}

> {%
    if (response.status === 403) {
        client.log("✅ 权限验证正常 - 普通用户无法创建商品");
    } else {
        client.log("❌ 权限验证异常");
    }
%}

### 1.5 参数验证测试 - 缺少必填字段
POST {{baseUrl}}/products
Authorization: Bearer {{merchantToken}}
Content-Type: application/json

{
  "name": "测试商品"
}

> {%
    if (response.status === 400) {
        client.log("✅ 参数验证正常 - 缺少必填字段");
    } else {
        client.log("❌ 参数验证异常");
    }
%}

### ================================================================================
### 🔍 查询商品
### ================================================================================

### 2.1 查询商品详情
GET {{baseUrl}}/products/{{productId}}

> {%
    if (response.status === 200) {
        var body = JSON.parse(response.body);
        if (body.data) {
            client.log("✅ 查询商品详情成功");
            client.log("📦 商品名称: " + body.data.name);
            client.log("💰 价格: " + body.data.basePrice);
            client.log("📂 分类: " + body.data.category);
        }
    } else {
        client.log("❌ 查询失败");
    }
%}

### 2.2 查询商品列表（分页）
GET {{baseUrl}}/products?page=1&size=10

> {%
    if (response.status === 200) {
        var body = JSON.parse(response.body);
        if (body.data && Array.isArray(body.data)) {
            client.log("✅ 查询商品列表成功");
            client.log("📊 商品数量: " + body.data.length);
        }
    }
%}

### 2.3 关键字搜索
GET {{baseUrl}}/products?keyword=iPhone&page=1&size=5

> {%
    if (response.status === 200) {
        var body = JSON.parse(response.body);
        if (body.data) {
            client.log("✅ 关键字搜索成功");
            client.log("🔍 搜索结果: " + body.data.length + " 个商品");
        }
    }
%}

### 2.4 按分类筛选
GET {{baseUrl}}/products?category=ELECTRONICS&page=1&size=10

> {%
    if (response.status === 200) {
        client.log("✅ 分类筛选成功");
    }
%}

### 2.5 综合筛选
GET {{baseUrl}}/products?page=1&size=10&keyword=iPhone&category=ELECTRONICS&status=LISTED

> {%
    if (response.status === 200) {
        client.log("✅ 综合筛选成功");
    }
%}

### ================================================================================
### ✏️ 更新商品
### ================================================================================

### 3.1 更新商品信息
PUT {{baseUrl}}/products/{{productId}}
Authorization: Bearer {{merchantToken}}
Content-Type: application/json

{
  "name": "iPhone 15 Pro Max (升级版)",
  "description": "全新未拆封，256GB，钛金属原色，支持5G网络，附赠配件",
  "basePrice": 8799.00,
  "category": "ELECTRONICS",
  "brand": "Apple",
  "model": "iPhone 15 Pro Max"
}

> {%
    if (response.status === 200) {
        var body = JSON.parse(response.body);
        client.log("✅ 商品信息更新成功");
        if (body.data) {
            client.log("📦 新名称: " + body.data.name);
            client.log("💰 新价格: " + body.data.basePrice);
        }
    } else {
        client.log("❌ 商品更新失败");
    }
%}

### 3.2 权限测试 - 普通用户尝试更新（应该失败）
PUT {{baseUrl}}/products/{{productId}}
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "name": "非法修改的商品名称",
  "description": "普通用户不应该能修改",
  "basePrice": 1.00
}

> {%
    if (response.status === 403) {
        client.log("✅ 权限验证正常 - 普通用户无法更新商品");
    } else {
        client.log("❌ 权限验证异常");
    }
%}

