### ================================================================================
### 🖼️ 商品图片管理
### ================================================================================

### 5.1 上传商品图片
POST {{baseUrl}}/products/{{productId}}/images
Authorization: Bearer {{merchantToken}}
Content-Type: application/json

{
  "imageUrl": "https://oss-example.com/products/iphone-new.jpg",
  "isPrimary": true
}

> {%
    if (response.status === 200) {
        client.log("✅ 商品图片上传成功");
    } else {
        client.log("❌ 商品图片上传失败");
    }
%}

### 5.2 上传多张图片
POST {{baseUrl}}/products/{{productId}}/images
Authorization: Bearer {{merchantToken}}
Content-Type: application/json

{
  "imageUrl": "https://oss-example.com/products/iphone-side.jpg",
  "isPrimary": false
}

### 5.3 删除商品图片
DELETE {{baseUrl}}/products/{{productId}}/images/img_123456
Authorization: Bearer {{merchantToken}}

> {%
    if (response.status === 200) {
        client.log("✅ 图片删除成功");
    } else if (response.status === 404) {
        client.log("⚠️ 图片不存在");
    } else {
        client.log("❌ 图片删除失败");
    }
%}

