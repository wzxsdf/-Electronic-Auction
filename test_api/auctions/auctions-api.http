}

> {%
    if (response.status === 200) {
        client.log("✅ 艺术品拍卖创建成功");
    }
%}

### 1.4 错误测试 - 商品不存在
POST {{baseUrl}}/auctions
Authorization: Bearer {{merchantToken}}
Content-Type: application/json

{
  "productId": 99999,
  "title": "不存在商品的拍卖",
  "startPrice": 100.00,
  "bidIncrement": 10.00,
  "startTime": "2026-06-08T10:00:00",
  "endTime": "2026-06-08T12:00:00"
}

> {%
    if (response.status === 400) {
        client.log("✅ 商品不存在验证正常");
    } else {
        client.log("❌ 商品不存在验证异常");
    }
%}

### 1.5 错误测试 - 时间不合理（结束时间早于开始时间）
POST {{baseUrl}}/auctions
Authorization: Bearer {{merchantToken}}
Content-Type: application/json

{
  "productId": {{productId}},
  "title": "时间错误的拍卖",
  "startPrice": 1000.00,
  "bidIncrement": 100.00,
  "startTime": "2026-06-08T12:00:00",
  "endTime": "2026-06-08T10:00:00"
}

> {%
    if (response.status === 400) {
        client.log("✅ 时间验证正常 - 结束时间不能早于开始时间");
    } else {
        client.log("❌ 时间验证异常");
    }
%}

### ================================================================================
### 🔍 查询拍卖活动
### ================================================================================

### 2.1 查询拍卖详情
GET {{baseUrl}}/auctions/{{auctionId}}

> {%
    if (response.status === 200) {
        var body = JSON.parse(response.body);
        if (body.data) {
            client.log("✅ 查询拍卖详情成功");
            client.log("🎵 拍卖ID: " + body.data.id);
            client.log("📝 标题: " + body.data.title);
            client.log("💰 当前价格: " + body.data.currentPrice);
            client.log("📊 状态: " + body.data.status);
        }
    } else {
        client.log("❌ 查询拍卖详情失败");
    }
%}

### 2.2 查询所有拍卖活动
GET {{baseUrl}}/auctions

> {%
    if (response.status === 200) {
        var body = JSON.parse(response.body);
        if (body.data && Array.isArray(body.data)) {
            client.log("✅ 查询所有拍卖成功");
            client.log("📊 拍卖数量: " + body.data.length);
        }
    }
%}

### 2.3 查询活跃拍卖（可出价）
GET {{baseUrl}}/auctions/active

> {%
    if (response.status === 200) {
        var body = JSON.parse(response.body);
        if (body.data && Array.isArray(body.data)) {
            client.log("✅ 查询活跃拍卖成功");
            client.log("📊 活跃拍卖数量: " + body.data.length);
            body.data.forEach(function(auction) {
                client.log("  - ID: " + auction.id + ", 标题: " + auction.title);
            });
        }
    }
%}

### 2.4 查询待开始拍卖
GET {{baseUrl}}/auctions?status=PENDING

> {%
    if (response.status === 200) {
        client.log("✅ 查询待开始拍卖成功");
    }
%}

### ================================================================================
### ▶️ 拍卖控制操作
### ================================================================================

### 3.1 开始拍卖
POST {{baseUrl}}/auctions/{{auctionId}}/start
Authorization: Bearer {{merchantToken}}

> {%
    if (response.status === 200) {
        client.log("✅ 拍卖开始成功");
    } else {
        client.log("❌ 拍卖开始失败");
    }
%}

### 3.2 取消拍卖（有原因）
POST {{baseUrl}}/auctions/{{auctionId}}/cancel?reason=商品质量问题，取消拍卖
Authorization: Bearer {{merchantToken}}

> {%
    if (response.status === 200) {
        client.log("✅ 拍卖取消成功");
    } else {
        client.log("❌ 拍卖取消失败");
    }
%}

### 3.3 取消拍卖（无原因）
POST {{baseUrl}}/auctions/{{auctionId}}/cancel
Authorization: Bearer {{merchantToken}}

> {%
    if (response.status === 200) {
        client.log("✅ 拍卖取消成功（无原因）");
    }
%}

### 3.4 权限测试 - 普通用户尝试开始拍卖（应该失败）
POST {{baseUrl}}/auctions/{{auctionId}}/start
Authorization: Bearer {{authToken}}

> {%
    if (response.status === 403) {
        client.log("✅ 权限验证正常 - 普通用户无法开始拍卖");
    } else {
        client.log("❌ 权限验证异常");
    }
%}

