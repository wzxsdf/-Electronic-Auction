### ================================================================================
### 🔒 安全测试
### ================================================================================

### 7.1 SQL注入测试
GET {{baseUrl}}/test/security/sql-injection?input=test'; DROP TABLE users;--

> {%
    if (response.status === 200) {
        var body = JSON.parse(response.body);
        if (body.data.safe === true) {
            client.log("✅ SQL注入防护正常");
        } else {
            client.log("❌ SQL注入防护异常");
        }
    }
%}

### 7.2 XSS攻击测试
GET {{baseUrl}}/test/security/xss?input=<script>alert('XSS')</script>

> {%
    if (response.status === 200) {
        var body = JSON.parse(response.body);
        if (body.data.safe === true) {
            client.log("✅ XSS防护正常");
        } else {
            client.log("❌ XSS防护异常");
        }
    }
%}

### 7.3 CSRF攻击测试
GET {{baseUrl}}/test/security/csrf

> {%
    if (response.status === 200) {
        client.log("✅ CSRF防护检查完成");
    }
%}

