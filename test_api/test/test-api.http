### ================================================================================
### 🎮 系统测试接口模块
### ================================================================================
### 功能：系统健康检查、功能测试、性能测试、压力测试等
### 依赖：部分需要认证，大部分公开
### 用途：开发调试、系统监控、问题诊断
### ================================================================================

@baseUrl = http://localhost:8080/api
@authToken = {{authToken}}

### ================================================================================
### 🏥 健康检查
### ================================================================================

### 1.1 基础健康检查
GET {{baseUrl}}/actuator/health

> {%
    if (response.status === 200) {
        var body = JSON.parse(response.body);
        if (body.status === "UP") {
            client.log("✅ 系统健康状态：正常");
        } else {
            client.log("⚠️ 系统健康状态：" + body.status);
        }
    }
%}

### 1.2 详细健康检查
GET {{baseUrl}}/actuator/health/detail

> {%
    if (response.status === 200) {
        var body = JSON.parse(response.body);
        client.log("✅ 详细健康检查");
        if (body.components) {
            client.log("💾 数据库: " + body.components.db.status);
            client.log("📡 Redis: " + body.components.redis.status);
            client.log("📦 OSS: " + body.components.oss.status);
        }
    }
%}

### 1.3 存活检查
GET {{baseUrl}}/actuator/health/liveness

> {%
    if (response.status === 200) {
        client.log("✅ 存活检查通过");
    }
%}

### 1.4 就绪检查
GET {{baseUrl}}/actuator/health/readiness

> {%
    if (response.status === 200) {
        client.log("✅ 就绪检查通过");
    }
%}

### ================================================================================
### 📊 系统信息
### ================================================================================

### 2.1 获取应用信息
GET {{baseUrl}}/actuator/info

> {%
    if (response.status === 200) {
        var body = JSON.parse(response.body);
        client.log("✅ 获取应用信息");
        if (body.app) {
            client.log("📦 应用名称: " + body.app.name);
            client.log("📦 版本: " + body.app.version);
            client.log("📦 描述: " + body.app.description);
        }
    }
%}

### 2.2 获取系统指标
GET {{baseUrl}}/actuator/metrics

> {%
    if (response.status === 200) {
        var body = JSON.parse(response.body);
        client.log("✅ 获取系统指标");
        if (body.names && Array.isArray(body.names)) {
            client.log("📊 可用指标数: " + body.names.length);
        }
    }
%}

### 2.3 获取JVM内存信息
GET {{baseUrl}}/actuator/metrics/jvm.memory.used

> {%
    if (response.status === 200) {
        client.log("✅ 获取JVM内存信息");
    }
%}

### 2.4 获取CPU使用率
GET {{baseUrl}}/actuator/metrics/process.cpu.usage

> {%
    if (response.status === 200) {
        client.log("✅ 获取CPU使用率");
    }
%}

### ================================================================================
### 🧪 功能测试接口
### ================================================================================

### 3.1 测试数据库连接
GET {{baseUrl}}/test/database

> {%
    if (response.status === 200) {
        client.log("✅ 数据库连接正常");
    } else {
        client.log("❌ 数据库连接异常");
    }
%}

### 3.2 测试Redis连接
GET {{baseUrl}}/test/redis

> {%
    if (response.status === 200) {
        client.log("✅ Redis连接正常");
    } else {
        client.log("❌ Redis连接异常");
    }
%}

### 3.3 测试OSS连接
GET {{baseUrl}}/test/oss

> {%
    if (response.status === 200) {
        client.log("✅ OSS连接正常");
    } else {
        client.log("❌ OSS连接异常");
    }
%}

### 3.4 测试JWT认证
GET {{baseUrl}}/test/auth

> {%
    if (response.status === 200) {
        client.log("✅ JWT认证正常");
    } else if (response.status === 401) {
        client.log("⚠️ JWT认证需要Token");
    }
%}

### 3.5 测试限流功能
GET {{baseUrl}}/test/rate-limit

> {%
    if (response.status === 200) {
        client.log("✅ 限流功能正常");
    } else if (response.status === 429) {
        client.log("⚠️ 触发限流");
    }
%}

### ================================================================================
### 🔥 性能测试
### ================================================================================

### 4.1 简单性能测试
GET {{baseUrl}}/test/performance/simple

> {%
    if (response.status === 200) {
        var body = JSON.parse(response.body);
        client.log("✅ 性能测试完成");
        client.log("⏱️ 响应时间: " + body.data.responseTime + "ms");
        client.log("📊 吞吐量: " + body.data.throughput + " req/s");
    }
%}

### 4.2 数据库查询性能测试
GET {{baseUrl}}/test/performance/database

> {%
    if (response.status === 200) {
        client.log("✅ 数据库性能测试完成");
    }
%}

### 4.3 并发测试
GET {{baseUrl}}/test/performance/concurrent?users=100&requests=1000

> {%
    if (response.status === 200) {
        var body = JSON.parse(response.body);
        client.log("✅ 并发测试完成");
        client.log("👥 并发用户数: " + body.data.concurrentUsers);
        client.log("📊 总请求数: " + body.data.totalRequests);
        client.log("✅ 成功请求: " + body.data.successfulRequests);
        client.log("❌ 失败请求: " + body.data.failedRequests);
    }
%}

