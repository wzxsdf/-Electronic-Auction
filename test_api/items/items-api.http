### ================================================================================
### 🎮 商品操作
### ================================================================================

### 3.1 开始拍卖商品
POST {{baseUrl}}/auction-items/{{auctionId}}/start
Authorization: Bearer {{merchantToken}}

> {%
    if (response.status === 200) {
        client.log("✅ 拍卖商品开始成功");
    } else {
        client.log("❌ 拍卖商品开始失败");
    }
%}

### 3.2 暂停拍卖商品
POST {{baseUrl}}/auction-items/{{auctionId}}/pause
Authorization: Bearer {{merchantToken}}

> {%
    if (response.status === 200) {
        client.log("✅ 拍卖商品暂停成功");
    }
%}

### 3.3 恢复拍卖商品
POST {{baseUrl}}/auction-items/{{auctionId}}/resume
Authorization: Bearer {{merchantToken}}

> {%
    if (response.status === 200) {
        client.log("✅ 拍卖商品恢复成功");
    }
%}

### 3.4 结束拍卖商品
POST {{baseUrl}}/auction-items/{{auctionId}}/end
Authorization: Bearer {{merchantToken}}

> {%
    if (response.status === 200) {
        client.log("✅ 拍卖商品结束成功");
    }
%}

### ================================================================================
### 💰 商品出价
### ================================================================================

### 4.1 对拍卖商品出价
POST {{baseUrl}}/auction-items/{{auctionId}}/bid
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "amount": 9500.00,
  "isAutoBid": false
}

> {%
    if (response.status === 200) {
        var body = JSON.parse(response.body);
        if (body.data) {
            client.log("✅ 出价成功");
            client.log("💰 出价金额: " + body.data.amount);
            client.log("🏆 是否最高: " + body.data.isHighestBid);
        }
    } else {
        client.log("❌ 出价失败");
    }
%}

### 4.2 批量出价（测试）
POST {{baseUrl}}/auction-items/{{auctionId}}/bids
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "bids": [
    {"amount": 9600.00, "delaySeconds": 10},
    {"amount": 9700.00, "delaySeconds": 20},
    {"amount": 9800.00, "delaySeconds": 30}
  ]
}

> {%
    if (response.status === 200) {
        client.log("✅ 批量出价成功");
    }
%}

### ================================================================================
### 📊 商品统计
### ================================================================================

### 5.1 获取拍卖商品统计
GET {{baseUrl}}/auction-items/{{auctionId}}/statistics

> {%
    if (response.status === 200) {
        var body = JSON.parse(response.body);
        if (body.data) {
            client.log("✅ 获取商品统计成功");
            client.log("📊 出价次数: " + body.data.bidCount);
            client.log("👥 参与人数: " + body.data.participantCount);
            client.log("💰 当前价格: " + body.data.currentPrice);
            client.log("⏰ 剩余时间: " + body.data.remainingTime);
        }
    }
%}

