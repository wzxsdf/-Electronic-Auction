### ================================================================================
### 🎯 拍卖商品模块接口测试
### ================================================================================
### 功能：拍卖商品查询、状态管理、房间关联等
### 依赖：需要拍卖ID（auctions模块）
### 权限：大部分公开，部分操作需要认证
### 说明：拍卖商品是拍卖的具体执行单元
### ================================================================================

@baseUrl = http://localhost:8080/api
@authToken = {{authToken}}
@merchantToken = {{merchantToken}}
@auctionId = {{auctionId}}

### ================================================================================
### 🔍 查询拍卖商品
### ================================================================================

### 1.1 查询拍卖商品详情
GET {{baseUrl}}/auction-items/{{auctionId}}

> {%
    if (response.status === 200) {
        var body = JSON.parse(response.body);
        if (body.data) {
            client.log("✅ 查询拍卖商品详情成功");
            client.log("🎯 商品ID: " + body.data.id);
            client.log("🎵 拍卖ID: " + body.data.auctionId);
            client.log("📦 商品名称: " + body.data.productName);
            client.log("💰 当前价格: " + body.data.currentPrice);
            client.log("📊 状态: " + body.data.status);
        }
    } else {
        client.log("❌ 查询拍卖商品详情失败");
    }
%}

### 1.2 查询所有拍卖商品
GET {{baseUrl}}/auction-items

> {%
    if (response.status === 200) {
        var body = JSON.parse(response.body);
        if (body.data && Array.isArray(body.data)) {
            client.log("✅ 查询所有拍卖商品成功");
            client.log("📊 商品数量: " + body.data.length);
        }
    }
%}

### 1.3 查询活跃拍卖商品
GET {{baseUrl}}/auction-items/active

> {%
    if (response.status === 200) {
        var body = JSON.parse(response.body);
        if (body.data && Array.isArray(body.data)) {
            client.log("✅ 查询活跃拍卖商品成功");
            client.log("📊 活跃商品数: " + body.data.length);
            body.data.forEach(function(item) {
                client.log("🎯 " + item.productName + " - " + item.currentPrice);
            });
        }
    }
%}

