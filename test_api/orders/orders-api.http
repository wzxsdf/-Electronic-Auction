### ================================================================================
### 🎵 查询拍卖相关订单
### ================================================================================

### 3.1 查询指定拍卖的订单
GET {{baseUrl}}/orders/auction/{{auctionId}}

> {%
    if (response.status === 200) {
        var body = JSON.parse(response.body);
        if (body.data && Array.isArray(body.data)) {
            client.log("✅ 查询拍卖订单成功");
            client.log("📊 订单数量: " + body.data.length);
            if (body.data.length > 0) {
                client.log("📋 订单ID: " + body.data[0].id);
                client.log("👤 买家: " + body.data[0].buyerId);
                client.log("💰 金额: " + body.data[0].amount);
            }
        }
    } else {
        client.log("❌ 查询拍卖订单失败");
    }
%}

### 3.2 查询不存在拍卖的订单
GET {{baseUrl}}/orders/auction/99999

> {%
    if (response.status === 404) {
        client.log("✅ 拍卖不存在验证正常");
    } else {
        client.log("⚠️ 拍卖不存在验证需要检查");
