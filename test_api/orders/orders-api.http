### ================================================================================
### 📊 订单统计信息
### ================================================================================

### 6.1 获取用户订单统计
GET {{baseUrl}}/orders/user/{{currentUserId}}/statistics

> {%
    if (response.status === 200) {
        var body = JSON.parse(response.body);
        if (body.data) {
            client.log("✅ 获取订单统计成功");
            client.log("📊 总订单数: " + body.data.totalOrders);
            client.log("💰 总消费金额: " + body.data.totalAmount);
            client.log("⏳ 待支付: " + body.data.pendingPayment);
            client.log("✅ 已完成: " + body.data.completed);
            client.log("❌ 已取消: " + body.data.cancelled);
        }
    } else {
        client.log("❌ 获取订单统计失败");
    }
%}

### 6.2 获取平台订单统计（管理员）
GET {{baseUrl}}/orders/statistics

> {%
    if (response.status === 200) {
        client.log("✅ 获取平台订单统计成功");
    } else if (response.status === 403) {
        client.log("⚠️ 需要管理员权限");
    }
%}

### ================================================================================
### 🔄 订单重新生成
### ================================================================================

### 7.1 重新生成已取消的订单
POST {{baseUrl}}/orders/{{orderId}}/regenerate
Authorization: Bearer {{authToken}}

> {%
    if (response.status === 200) {
        var body = JSON.parse(response.body);
        if (body.data && body.data.newOrderId) {
            client.log("✅ 订单重新生成成功");
            client.log("📋 新订单ID: " + body.data.newOrderId);
        }
    } else if (response.status === 400) {
        client.log("⚠️ 订单状态不允许重新生成");
    }
%}

### ================================================================================
### 💳 支付相关接口
### ================================================================================

### 8.1 获取订单支付信息
GET {{baseUrl}}/orders/{{orderId}}/payment

> {%
    if (response.status === 200) {
        var body = JSON.parse(response.body);
        if (body.data) {
            client.log("✅ 获取支付信息成功");
            client.log("💰 应付金额: " + body.data.amount);
            client.log("🕐 过期时间: " + body.data.expireTime);
            client.log("📝 支付方式: " + body.data.paymentMethods);
        }
    }
%}

### 8.2 创建支付
POST {{baseUrl}}/payments
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "orderId": {{orderId}},
  "paymentMethod": "ALIPAY",
  "amount": 8899.00
}

> {%
    if (response.status === 200) {
        var body = JSON.parse(response.body);
        if (body.data) {
            client.log("✅ 创建支付成功");
            client.log("💳 支付ID: " + body.data.paymentId);
            client.log("🔗 支付URL: " + body.data.paymentUrl);
        }
    } else {
        client.log("❌ 创建支付失败");
    }
%}

