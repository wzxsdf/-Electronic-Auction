  "timezone": "Asia/Shanghai",
  "currency": "CNY",
  "notificationEnabled": true,
  "emailNotification": true,
  "smsNotification": false
}

> {%
    if (response.status === 200) {
        client.log("✅ 用户偏好更新成功");
    }
%}

### 7.2 获取用户偏好
GET {{baseUrl}}/users/{{currentUserId}}/preferences

> {%
    if (response.status === 200) {
        client.log("✅ 获取用户偏好成功");
    }
%}

### ================================================================================
### 📱 用户地址管理
### ================================================================================

### 8.1 添加收货地址
POST {{baseUrl}}/users/{{currentUserId}}/addresses
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "receiverName": "张三",
  "phone": "13800138000",
  "province": "北京市",
  "city": "北京市",
  "district": "朝阳区",
  "detail": "xxx路xxx号xxx室",
  "isDefault": true
}

> {%
    if (response.status === 200) {
        client.log("✅ 添加收货地址成功");
    }
%}

### 8.2 查询收货地址列表
GET {{baseUrl}}/users/{{currentUserId}}/addresses

> {%
    if (response.status === 200) {
        client.log("✅ 查询收货地址成功");
    }
%}

### 8.3 更新收货地址
PUT {{baseUrl}}/users/{{currentUserId}}/addresses/{{addressId}}
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "receiverName": "李四",
  "phone": "13900139000",
  "isDefault": true
}

> {%
    if (response.status === 200) {
        client.log("✅ 更新收货地址成功");
    }
%}

### 8.4 删除收货地址
DELETE {{baseUrl}}/users/{{currentUserId}}/addresses/{{addressId}}
Authorization: Bearer {{authToken}}

> {%
    if (response.status === 200) {
        client.log("✅ 删除收货地址成功");
    }
%}

### ================================================================================
### 🔒 安全测试
### ================================================================================

### 9.1 测试并发修改
### 同时发送多个修改请求，验证数据一致性

### 9.2 测试XSS攻击
PUT {{baseUrl}}/users/{{currentUserId}}
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "nickname": "<script>alert('XSS')</script>"
}

> {%
    if (response.status === 400) {
        client.log("✅ XSS防护正常");
    } else {
        client.log("⚠️ XSS防护需要加强");
    }
%}

### 9.3 测试SQL注入
GET {{baseUrl}}/users?keyword=test'; DROP TABLE users;--

> {%
    if (response.status === 200) {
        var body = JSON.parse(response.body);
        if (body.data && !body.data.error) {
            client.log("✅ SQL注入防护正常");
        }
    }
%}

### ================================================================================
### 💡 测试注意事项
### ================================================================================

### 1. 用户信息涉及隐私，注意权限控制
### 2. 密码修改后需要重新登录
### 3. 管理员功能需要使用adminToken
### 4. 用户状态修改会立即生效
### 5. 邮箱和手机号需要唯一性验证
### 6. 地址信息可能用于订单配送

### ================================================================================